{
  "name": "gestao_oficina",
  "private": true,
  "version": "1.9.1",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "electron:dev": "cross-env ELECTRON_START_URL=http://localhost:5000 concurrently \"npm run dev\" \"wait-on http://localhost:5000 && electron .\"",
    "electron:start": "electron .",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=4096 vite build",
    "predist": "node scripts/prepare-installer-assets.cjs",
    "dist": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false VITE_ELECTRON=true npm run build && electron-builder --win nsis",
    "predist:inno": "node scripts/prepare-installer-assets.cjs",
    "dist:inno": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false VITE_ELECTRON=true npm run build && electron-builder --win dir && node scripts/set-exe-icon.cjs && node scripts/build-inno-installer.cjs",
    "postdist": "node scripts/set-exe-icon.cjs",
    "build:mobile": "npm run build && npx cap sync",
    "sync:mobile": "npx cap sync",
    "open:android": "npx cap open android",
    "open:ios": "npx cap open ios",
    "lint": "eslint .",
    "preview": "vite preview",
    "email:api": "node email-api/src/server.js"
  },
  "build": {
    "appId": "com.algartempo.programa",
    "productName": "ALGARTEMPO",
    "asar": true,
    "icon": "build/exeicon.ico",
    "directories": {
      "output": "release"
    },
    "extraMetadata": {
      "main": "electron/main.cjs",
      "type": "commonjs"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/exeicon.ico",
      "signAndEditExecutable": false,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerSidebar": "build/installer/sidebar.bmp",
      "uninstallerSidebar": "build/installer/sidebar-uninstall.bmp",
      "installerHeader": "build/installer/header.bmp",
      "include": "build/installer/installer.nsh",
      "installerIcon": "build/exeicon.ico",
      "uninstallerIcon": "build/exeicon.ico",
      "installerHeaderIcon": "build/exeicon.ico"
    }
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/supabase-js": "^2.89.0",
    "@types/leaflet": "^1.9.21",
    "@types/react-grid-layout": "^1.3.6",
    "basic-ftp": "^5.1.0",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "dotenv": "^17.2.3",
    "jspdf": "^3.0.4",
    "jspdf-autotable": "^5.0.7",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.561.0",
    "pdfjs-dist": "^5.4.530",
    "pg": "^8.16.3",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-grid-layout": "^2.2.2",
    "react-hot-toast": "^2.6.0",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.10.1",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.4.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.6",
    "rcedit": "^5.0.2",
    "sharp": "^0.32.6",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.18.0",
    "vite": "^5.4.11",
    "vite-plugin-pwa": "^0.21.1",
    "wait-on": "^9.0.10"
  }
}
