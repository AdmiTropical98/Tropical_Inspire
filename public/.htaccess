RewriteEngine On

# Executar ficheiros reais primeiro (PHP, imagens, etc)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Executar pastas reais
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Nunca redirecionar API para React
RewriteRule ^api/ - [L]

# SPA fallback para React
RewriteRule ^ index.html [L]
